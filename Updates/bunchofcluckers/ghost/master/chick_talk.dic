	repNoisyBuk
	repeatingWord("cluck",1,3)
	repeatingWord("BAWK",2,4)
	"{She thought she saw a hawk, but it was a false alarm.}"
	"{She can talk your ear off in her chicken ways.}"
	"{She's a loud one.}"
	"BAKAWK!"
	"{Sounds like she tried to crow, but it just a bunch of screaming.}"

}

lostGreeting{
