

menuOpeners{
	{
		"{The chickens are clucking around in the yard.}"
		"{One of the chickens seems to have caught %(prey).}" 
		"{The chickens are scratching around the yard.}"
		"{A good day for chickens.}"
		"{You hear that a chicken has laid an egg nearby.}"
		if chickensHere[4] == 1; "{The duck is trying to get into the water again.}" 
		"%(tips)"
	}
	{
		if activechickens >= 2{
			_chickenPair = getChickenPair
			"{%(_chickenPair[0]) is fighting %(_chickenPair[1]) over a worm they found.}"
		}
		_chickenBroody = getChickenPersonality(1)
		_chickenBullied = getChickenPersonality(2)
		if _chickenBroody != -1 && _chickenBullied != -1{
			"{%_chickenBroody is pecking at %_chickenBullied.}"
		}
		"{One of the chickens has found themself on the roof of the coop.}"
		
	}
	"%(tips)"
	"%(chickenFacts)"
}


tips{
	"{Tip: You can sell your eggs at the shop.}"
	"{Tip: Keep your food stocked, you never know until it's too late.}"
	"{Tip: You can pet the chickens! Go ahead and try it.}"
	"{Tip: The water is all in one place, so you only have to worry about refilling the tank.}"
	"{Tip: You can buy new chickens in the shop, more chickens means more eggs.}"
}


chickenFacts{
"{Fact: That cat was lured here by the chick. It's too bad, but at least you don't have to feed him.}"
"{Fun Fact: Brahmas are one of the biggest chickens in the world!}"
"{Fun Fact: If a flock of hens doesn't have a rooster, one of the hens takes the place of the rooster.}"
"{Fun Fact: Chickens have a ranking system called the pecking order!}"
"{Fun Fact: You can tell how full a chicken is by feeling their chest for their crop. }"
"{Fun Fact: Eggs don't always grow new chickens.}"

"{Fun Fact: Sometimes eggs can come with two or more yolks!}"
"{Chickens come in all shapes and sizes!}"

}

