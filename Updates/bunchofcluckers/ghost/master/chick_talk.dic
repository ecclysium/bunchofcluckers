//Shorthands for clucking amounts
repBok{
	repeatingWord("bok",1,8)
}

repCluck{
	repeatingWord("cluck",1,8)
}

repBuk{
	repeatingWord("buk",1,8)
	
}


repNoisyBok{
	repeatingWord("bok",5,10)
}

repNoisyCluck{
	repeatingWord("cluck",5,10)
}

repNoisyBuk{
	repeatingWord("buk",5,10)
	
}


repBroodyBok{
	repeatingWord("bok",1,3)
}

repBroodyCluck{
	repeatingWord("cluck",1,3)
}

repBroodyBuk{
	repeatingWord("buk",1,3)
	
}

//Repeat argv0 1-8 times
//arg1 is min 
//arg2 is max
repeatingWord : all{
	_num = RAND(_argv[2] - _argv[1]) + _argv[1]
	for _i = 0; _i < _num; _i++{
		"%_argv[0]"
	}

}


